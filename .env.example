# =============================================================================
# AegisRAG - Environment Variables
# Copy this file to .env and fill in your values.
# =============================================================================

# --- Hugging Face ---
HF_TOKEN=your_huggingface_token_here
HF_HOME=~/.cache/huggingface

# --- Device ---
CUDA_VISIBLE_DEVICES=0
AEGIS_DEVICE=auto               # auto | cpu | cuda | mps

# --- Paths (override config/base.yaml defaults) ---
AEGIS_CONFIG_PATH=config/base.yaml
AEGIS_VECTOR_DB_PATH=data/vectordb
AEGIS_BM25_INDEX_PATH=data/bm25_index.pkl
AEGIS_AUDIT_DB_PATH=data/audit.db
AEGIS_RAW_DOCS_DIR=data/raw_docs
AEGIS_CHECKPOINT_DIR=checkpoints
AEGIS_LOG_DIR=logs

# --- Generator GGUF (for llama-cpp-python inference) ---
AEGIS_GGUF_PATH=
AEGIS_GGUF_N_GPU_LAYERS=-1

# --- Serving ---
AEGIS_HOST=0.0.0.0
AEGIS_PORT=8000
AEGIS_WORKERS=1

# --- Logging ---
AEGIS_LOG_LEVEL=INFO

# --- Weights & Biases (optional) ---
WANDB_DISABLED=true
WANDB_PROJECT=aegisrag
WANDB_ENTITY=

# --- Local teacher (no APIs) ---
# Primary: Qwen2.5-7B-Instruct; override to Mistral-7B if preferred.
# AEGIS_LOCAL_MODEL=Qwen/Qwen2.5-7B-Instruct

# --- Misc ---
TOKENIZERS_PARALLELISM=false
OMP_NUM_THREADS=4
